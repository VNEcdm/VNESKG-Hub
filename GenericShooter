local currentSize = 5
local currentTransparency = 0.7
local enabled = false

local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local LocalPlayer = Players.LocalPlayer

local lastHitboxStates = {}
local originalHitboxStates = {}

local function isValidTarget(model)
	if not model or not model:IsA("Model") then
		return false
	end

	-- Não aplica no próprio personagem
	if model == LocalPlayer.Character then
		return false
	end

	local humanoid = model:FindFirstChildOfClass("Humanoid")
	local root = model:FindFirstChild("HumanoidRootPart")

	return humanoid ~= nil
		and humanoid.Health > 0
		and root ~= nil
		and root:IsA("BasePart")
end

local function saveOriginalState(root)
	if originalHitboxStates[root] then
		return
	end

	originalHitboxStates[root] = {
		Size = root.Size,
		Transparency = root.Transparency,
		Color = root.Color,
		Material = root.Material,
		CanCollide = root.CanCollide,
		CanQuery = root.CanQuery,
		CanTouch = root.CanTouch
	}
end

local function applyHitboxToCharacter(character, size, transparency)
	if not isValidTarget(character) then
		return
	end

	local root = character:FindFirstChild("HumanoidRootPart")

	if not root then
		return
	end

	saveOriginalState(root)

	local state = lastHitboxStates[root]

	if not state
		or state.size ~= size
		or state.transparency ~= transparency then

		pcall(function()
			root.Size = Vector3.new(size, size, size)
			root.Transparency = transparency
			root.Color = Color3.fromRGB(255, 0, 0)
			root.Material = Enum.Material.ForceField
			root.CanCollide = false
			root.CanQuery = true
			root.CanTouch = true
		end)

		lastHitboxStates[root] = {
			size = size,
			transparency = transparency
		}
	end
end

local function resetHitboxCharacter(character)
	if not character or not character:IsA("Model") then
		return
	end

	local root = character:FindFirstChild("HumanoidRootPart")

	if not root then
		return
	end

	local originalState = originalHitboxStates[root]

	pcall(function()
		if originalState then
			root.Size = originalState.Size
			root.Transparency = originalState.Transparency
			root.Color = originalState.Color
			root.Material = originalState.Material
			root.CanCollide = originalState.CanCollide
			root.CanQuery = originalState.CanQuery
			root.CanTouch = originalState.CanTouch
		else
			root.Size = Vector3.new(2, 2, 1)
			root.Transparency = 1
			root.Color = Color3.fromRGB(163, 162, 165)
			root.Material = Enum.Material.Plastic
			root.CanCollide = false
			root.CanQuery = true
			root.CanTouch = true
		end
	end)

	lastHitboxStates[root] = nil
	originalHitboxStates[root] = nil
end

local function setHitboxSize(size, transparency)
	for _, object in ipairs(Workspace:GetDescendants()) do
		if isValidTarget(object) then
			applyHitboxToCharacter(object, size, transparency)
		end
	end
end

local function resetHitboxes()
	for root in pairs(originalHitboxStates) do
		if root and root.Parent then
			resetHitboxCharacter(root.Parent)
		end
	end

	table.clear(lastHitboxStates)
	table.clear(originalHitboxStates)
end

local characterConnections = {}

local function registerCharacter(character)
	if not character or not character:IsA("Model") then
		return
	end

	if characterConnections[character] then
		return
	end

	characterConnections[character] = character.ChildAdded:Connect(function(child)
		if child.Name == "HumanoidRootPart" then
			task.wait(0.2)

			if enabled and isValidTarget(character) then
				applyHitboxToCharacter(
					character,
					currentSize,
					currentTransparency
				)
			end
		end
	end)

	if enabled and isValidTarget(character) then
		applyHitboxToCharacter(
			character,
			currentSize,
			currentTransparency
		)
	end
end

local function characterAddedFunc(player)
	player.CharacterAdded:Connect(function(character)
		character:WaitForChild("Humanoid", 8)
		character:WaitForChild("HumanoidRootPart", 8)

		registerCharacter(character)

		if enabled and player ~= LocalPlayer then
			task.wait(0.2)

			applyHitboxToCharacter(
				character,
				currentSize,
				currentTransparency
			)
		end
	end)

	if player.Character then
		registerCharacter(player.Character)
	end
end

-- Registra todos os jogadores
for _, player in ipairs(Players:GetPlayers()) do
	characterAddedFunc(player)
end

Players.PlayerAdded:Connect(function(player)
	characterAddedFunc(player)
end)

-- Registra NPCs que já existem
for _, object in ipairs(Workspace:GetDescendants()) do
	if object:IsA("Model") then
		registerCharacter(object)
	end
end

-- Registra NPCs criados depois
Workspace.DescendantAdded:Connect(function(object)
	if object:IsA("Model") then
		task.wait(0.2)
		registerCharacter(object)

	elseif object.Name == "HumanoidRootPart"
		and object:IsA("BasePart") then

		local character = object.Parent

		task.wait(0.2)

		if character and character:IsA("Model") then
			registerCharacter(character)

			if enabled and isValidTarget(character) then
				applyHitboxToCharacter(
					character,
					currentSize,
					currentTransparency
				)
			end
		end
	end
end)

Workspace.DescendantRemoving:Connect(function(object)
	if object:IsA("Model") and characterConnections[object] then
		characterConnections[object]:Disconnect()
		characterConnections[object] = nil
	end

	if object:IsA("BasePart") then
		lastHitboxStates[object] = nil
		originalHitboxStates[object] = nil
	end
end)

local hitboxUpdateThread = nil
local hitboxUpdateFlag = false

local function startHitboxUpdater()
	if hitboxUpdateThread then
		return
	end

	hitboxUpdateFlag = true

	hitboxUpdateThread = task.spawn(function()
		while hitboxUpdateFlag do
			if enabled then
				setHitboxSize(
					currentSize,
					currentTransparency
				)
			end

			task.wait(2)
		end

		hitboxUpdateThread = nil
	end)
end

local function stopHitboxUpdater()
	hitboxUpdateFlag = false
end

HitboxTab:CreateToggle({
	Name = "Enable Hitbox Expander",
	CurrentValue = false,

	Callback = function(state)
		enabled = state

		if state then
			setHitboxSize(
				currentSize,
				currentTransparency
			)

			startHitboxUpdater()
		else
			stopHitboxUpdater()
			resetHitboxes()
		end
	end
})

