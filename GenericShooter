local noclip = false
local noclipConnection = nil

local function trulyNoclip()
	local char = LocalPlayer.Character
	if char then
		for _, v in ipairs(char:GetDescendants()) do
			if v:IsA("BasePart") then
				v.CanCollide = false
				v.CanTouch = false
				v.CanQuery = false
				if v:FindFirstAncestorWhichIsA("Model") == char then
					v.CanCollide = false
					v.CanTouch = false
					v.CanQuery = false
				end
			end
		end
	end
end

local function trulyUndoNoclip()
	local char = LocalPlayer.Character
	if char then
		for _, v in ipairs(char:GetDescendants()) do
			if v:IsA("BasePart") then
				v.CanCollide = true
				v.CanTouch = true
				v.CanQuery = true
			end
		end
	end
end

