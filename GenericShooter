local desiredJumpPower = 50
local lastJumpPower = desiredJumpPower

local function applyJumpPower(char)
	local hum = char and char:FindFirstChildOfClass("Humanoid")
	if hum then
		if hum.UseJumpPower ~= nil then
			hum.UseJumpPower = true
		end
		if hum.JumpPower then
			hum.JumpPower = desiredJumpPower
		end
		if hum.JumpHeight then
			local gravity = workspace.Gravity or 196.2
			hum.JumpHeight = (desiredJumpPower^2) / (200 * gravity)
		end
	end
end

RunService.RenderStepped:Connect(function()
	local char = LocalPlayer.Character
	if char then
		local hum = char:FindFirstChildOfClass("Humanoid")
		if hum then
			if hum.UseJumpPower ~= nil and hum.UseJumpPower ~= true then
				hum.UseJumpPower = true
			end
			if hum.JumpPower ~= desiredJumpPower then
				hum.JumpPower = desiredJumpPower
			end
			if hum.JumpHeight then
				local gravity = workspace.Gravity or 196.2
				local targetHeight = (desiredJumpPower^2) / (200 * gravity)
				if math.abs(hum.JumpHeight - targetHeight) > 0.01 then
					hum.JumpHeight = targetHeight
				end
			end
		end
	end
end)

LocalPlayer.CharacterAdded:Connect(function(char)
	char:WaitForChild("Humanoid", 5)
	task.wait(0.1)
	applyJumpPower(char)
end)

