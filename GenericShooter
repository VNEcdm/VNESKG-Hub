			)
		end
	end
})


local ESPTab = Window:CreateTab("ESP", "eye")
ESPTab:CreateSection("ESP Features")

local ESPBoxesEnabled = false
local ESPTracersEnabled = false
local ESPTeamNameEnabled = false
local ESPDistanceEnabled = false
local ESPNameEnabled = false

local RunService = game:GetService("RunService")

local Draw = Drawing
local ESPObjects = {}

local function clearESP()
	for i,v in pairs(ESPObjects) do
		for _,obj in pairs(v) do
			if obj then
				if typeof(obj.Remove) == "function" then
					obj:Remove()
				elseif typeof(obj.Destroy) == "function" then
					obj:Destroy()
				elseif obj.Parent then
					obj.Parent = nil
				end
			end
		end
	end
	ESPObjects = {}
end

local function espUpdate()
	local existingTargets = {}

	for _,model in ipairs(workspace:GetDescendants()) do
		if model:IsA("Model")
			and model ~= LocalPlayer.Character
			and model:FindFirstChildOfClass("Humanoid")
			and model:FindFirstChildOfClass("Humanoid").Health > 0
			and model:FindFirstChild("HumanoidRootPart") then

			local player = Players:GetPlayerFromCharacter(model)
			local target = player or model

			existingTargets[target] = true

			local root = model.HumanoidRootPart
			local objs = ESPObjects[target]
			local cam = workspace.CurrentCamera

			if root and cam then
				local pos, onscreen = cam:WorldToViewportPoint(root.Position)

				if ESPBoxesEnabled and Draw then
					if not objs or not objs.box then
						if not objs then
							objs = {}
						end

						local box = Draw.new("Square")
						box.Color = Color3.new(1, 0, 0)
						box.Thickness = 2
						box.Filled = false

						objs.box = box
						ESPObjects[target] = objs
					end

					objs.box.Size = Vector2.new(28, 56)
					objs.box.Position = Vector2.new(pos.X - 14, pos.Y - 28)
					objs.box.Visible = onscreen
				elseif objs and objs.box then
					objs.box.Visible = false
				end

				if ESPTracersEnabled and Draw then
					if not objs or not objs.tracer then
						if not objs then
							objs = {}
						end

						local tracer = Draw.new("Line")
						tracer.Color = Color3.new(1, 0, 0)
						tracer.Thickness = 2

						objs.tracer = tracer
						ESPObjects[target] = objs
					end

					objs.tracer.From = Vector2.new(
						cam.ViewportSize.X / 2,
						cam.ViewportSize.Y
					)

					objs.tracer.To = Vector2.new(pos.X, pos.Y)
					objs.tracer.Visible = onscreen
				elseif objs and objs.tracer then
					objs.tracer.Visible = false
				end

				local textLines = {}

				if ESPNameEnabled then
					if player then
						table.insert(textLines, player.Name)
					else
						table.insert(textLines, model.Name)
					end
				end

				if ESPDistanceEnabled then
					table.insert(
						textLines,
						"[" .. math.floor(
							(root.Position - cam.CFrame.Position).Magnitude
						) .. "m]"
					)
				end

				if ESPTeamNameEnabled then
					if player then
						table.insert(
							textLines,
							player.Team and player.Team.Name or "NoTeam"
						)
					else
						table.insert(textLines, "NPC")
					end
				end

				if #textLines > 0 and Draw then
					if not objs or not objs.text then
						if not objs then
							objs = {}
						end

						local text = Draw.new("Text")
						text.Color = Color3.new(1, 0, 0)
						text.Size = 15
						text.Center = true
						text.Outline = true

						objs.text = text
						ESPObjects[target] = objs
					end

					objs.text.Text = table.concat(textLines, " ")
					objs.text.Position = Vector2.new(pos.X, pos.Y - 18)
					objs.text.Visible = onscreen
				elseif objs and objs.text then
					objs.text.Visible = false
				end
			end
		end
	end

	for target, objs in pairs(ESPObjects) do
		if not existingTargets[target] then
			for _,obj in pairs(objs) do
				if obj and typeof(obj.Remove) == "function" then
					obj:Remove()
				elseif obj and typeof(obj.Destroy) == "function" then
					obj:Destroy()
				end
			end

			ESPObjects[target] = nil
		end
	end
end

local espConnection
local lastAnyESP = false

local function checkESP()
	local anyESP = ESPBoxesEnabled or ESPTracersEnabled or ESPDistanceEnabled or ESPTeamNameEnabled or ESPNameEnabled
	if anyESP and not espConnection then
		espConnection = RunService.RenderStepped:Connect(espUpdate)
	elseif not anyESP and espConnection then
		espConnection:Disconnect()
		espConnection = nil
		clearESP()
	end
	lastAnyESP = anyESP
end

